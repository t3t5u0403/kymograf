{
  "name": "kymograf",
  "private": true,
  "license": "MIT",
  "author": "t3t5u0403",
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "fixtures": "node scripts/make-fixtures.mjs",
    "app": "electron .",
    "pack": "npm run build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.t3t5u0403.kymograf",
    "productName": "kymograf",
    "files": ["dist/**", "electron/**", "build/icon.png", "package.json"],
    "directories": { "buildResources": "build", "output": "release" },
    "linux": {
      "target": ["AppImage"],
      "category": "AudioVideo",
      "desktopName": "kymograf",
      "syncDesktopName": true
    },
    "win": { "target": ["nsis"] },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.video"
    },
    "publish": { "provider": "github", "owner": "t3t5u0403", "repo": "kymograf" }
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "mp4-muxer": "^5.1.0",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
